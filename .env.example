PORT=3001

# pino log level (e.g. info, warn, error, silent).
# LOG_LEVEL=info

# Optional: max POST /workflows/:id/execute requests per client IP per rolling minute. Unset or empty = no limit.
# WORKFLOW_RATE_LIMIT_PER_MINUTE=120

# Comma-separated browser origins allowed for CORS. When unset, any origin is allowed (dev-friendly).
# CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Required for x402 payment challenges (Base USDC EIP-3009 payee address).
X402_RECEIVING_ADDRESS=

# Relayer wallet: submits `transferWithAuthorization` on Base (needs ETH for gas). User USDC moves payer → payee.
BASE_SETTLEMENT_PRIVATE_KEY=

# Optional Base mainnet RPC (defaults to public mainnet.base.org).
# BASE_RPC_URL=https://mainnet.base.org

# KeeperHub workspace (listed workflows + POST …/call). Defaults to https://app.keeperhub.com if unset.
# KEEPERHUB_BASE_URL=https://app.keeperhub.com

# API key for your KeeperHub org (Settings → API / MCP). Used for POST …/workflows/{slug}/call.
# For local dev you can rely on this alone (no Bearer on each request). In production, map users to keys instead.
# DEFAULT_KEEPERHUB_API_KEY=

# Target workflow: dashboard **id** or **listedSlug** (default `simple-workflow`). The `/call` path uses listedSlug;
# id → listedSlug resolution uses GET /api/mcp/workflows + your API key.
# KEEPERHUB_SIMPLE_WORKFLOW_ID=pbkb9kru29wuddz5qasck
# KEEPERHUB_SIMPLE_WORKFLOW_SLUG=simple-workflow

# OG beta signup workflow (`POST /workflows/og-beta-signup/execute`). Default listed slug `og-beta-signup`.
# KEEPERHUB_OG_BETA_SIGNUP_WORKFLOW_ID=
# KEEPERHUB_OG_BETA_SIGNUP_WORKFLOW_SLUG=og-beta-signup

# OG paid beta signup (`POST /workflows/og-paid-beta-signup/execute?…`). Default listed slug `og-paid-beta-signup`.
# KEEPERHUB_OG_PAID_BETA_SIGNUP_WORKFLOW_ID=
# KEEPERHUB_OG_PAID_BETA_SIGNUP_WORKFLOW_SLUG=og-paid-beta-signup

# Lendpay paid beta signup (`POST /workflows/lendpay-paid-beta-signup/execute?…`). Default listed slug `lendpay-paid-beta-signup`.
# KEEPERHUB_LENDPAY_PAID_BETA_SIGNUP_WORKFLOW_ID=
# KEEPERHUB_LENDPAY_PAID_BETA_SIGNUP_WORKFLOW_SLUG=lendpay-paid-beta-signup

# claimlayer-paid-claimall (`POST /workflows/claimlayer-paid-claimall/execute`). Default listed slug `claimlayer-paid-claimall`.
# KEEPERHUB_CLAIMLAYER_PAID_CLAIMALL_WORKFLOW_ID=
# KEEPERHUB_CLAIMLAYER_PAID_CLAIMALL_WORKFLOW_SLUG=claimlayer-paid-claimall
